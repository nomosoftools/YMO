{
  "manifest_version": 3,
  "name": "Yellow Magic Orchestra",
  "version": "4.0",
  "description": "Robust, high-performance text highlighter with undo.",
  "permissions": ["storage"], 
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
