{
  "manifest_version": 3,
  "name": "Yellow Magic Orchestra",
  "version": "4.0",
  "description": "Highlight text on webpages",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/YMO16.png",
      "48": "icons/YMO48.png",
      "128": "icons/YMO128.png"
    }
  },
  "icons": {
    "16": "icons/YMO16.png",
    "48": "icons/YMO48.png",
    "128": "icons/YMO128.png"
  }
}
