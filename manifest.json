{
  "manifest_version": 3,
  "name": "Yellow Magic Orchestra",
  "version": "4.0",
  "description": "Highlight text on webpages",
  "permissions": ["activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
